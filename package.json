{
  "name": "swiftsite-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "scope:check": "node scripts/check-capabilities.mjs",
    "test": "pnpm exec vitest run",
    "test:unit": "pnpm exec vitest run tests/unit",
    "test:integration": "pnpm exec vitest run tests/integration",
    "qa:heavy": "powershell -ExecutionPolicy Bypass -File scripts/qa-heavy-runtime.ps1 -BaseUrl http://localhost:3000",
    "qa:gate": "pnpm test:unit && pnpm test:integration && pnpm scope:check && pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
